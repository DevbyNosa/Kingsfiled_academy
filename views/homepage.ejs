<section class="admissions-process-section">
  <div class="process-header">
    <h2>Simple Steps to Join KingsField Academy</h2>
    <p>We make securing your child's educational future straightforward and stress-free.</p>
  </div>

  <div class="process-grid">
    <!-- Step 1 -->
    <div class="process-card">
      <div class="step-badge">1</div>
      <h3>Submit Application</h3>
      <p>Click the <a href="/apply" class="apply-now-process">Apply Now</a> button to fill out our digital form, or visit our main office in Benin City to pick up an admission packet.</p>
    </div>

    <!-- Step 2 -->
    <div class="process-card">
      <div class="step-badge">2</div>
      <h3>Entrance Assessment</h3>
      <p>Your child will sit for a standard placement evaluation to help our faculty determine their current academic strength and grade readiness.</p>
    </div>

    <!-- Step 3 -->
    <div class="process-card">
      <div class="step-badge">3</div>
      <h3>Interview & Review</h3>
      <p>A brief interactive session between our administration team, the student, and parents to discuss learning goals and core expectations.</p>
    </div>

    <!-- Step 4 -->
    <div class="process-card">
      <div class="step-badge">4</div>
      <h3>Welcome to KingsField</h3>
      <p>Upon successful verification, receive your official acceptance letter, complete the registration fee payment, and collect uniforms.</p>
    </div>
  </div>
</section>

