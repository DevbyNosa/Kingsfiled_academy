<%- include("../partials/navbar.ejs") %>

<section class="portal-section">
  <div class="portal-container">
    
    <div class="portal-tabs">
      <button class="tab-btn active" data-tab="student">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C13.1 2 14 2.9 14 4C14 5.1 13.1 6 12 6C10.9 6 10 5.1 10 4C10 2.9 10.9 2 12 2Z" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 6V12" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 22C16.4183 22 20 18.4183 20 14C20 9.58172 16.4183 6 12 6C7.58172 6 4 9.58172 4 14C4 18.4183 7.58172 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Student Login
      </button>
      <button class="tab-btn" data-tab="teacher">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z" stroke="currentColor" stroke-width="1.5"/>
          <path d="M22 6L12 13L2 6" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Teacher Login
      </button>
      <button class="tab-btn" data-tab="parent">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="12" cy="9" r="3" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Parent Portal
      </button>
    </div>

    <!-- Student Login Form -->
    <div class="tab-content active" id="student">
      <div class="portal-card">
        <div class="portal-card-header">
          <div class="portal-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C13.1 2 14 2.9 14 4C14 5.1 13.1 6 12 6C10.9 6 10 5.1 10 4C10 2.9 10.9 2 12 2Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 6V12" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 22C16.4183 22 20 18.4183 20 14C20 9.58172 16.4183 6 12 6C7.58172 6 4 9.58172 4 14C4 18.4183 7.58172 22 12 22Z" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h2>Student Login</h2>
          <p>Access your grades, assignments, and class schedule</p>
        </div>
        
        <form class="portal-form" action="/login/student" method="POST">
          <div class="form-group">
            <label>Admission Number</label>
            <%- include('../partials/forms.ejs', { type: 'text', name: 'admission_no', placeholder: 'KF/2026/001' }) %>
          </div>
          
          <div class="form-group">
            <label>Password</label>
            <div class="password-wrapper">
              <%- include('../partials/forms.ejs', { type: 'password', name: 'password', placeholder: 'Enter your password' }) %>
              <button type="button" class="toggle-password">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </button>
            </div>
          </div>
          
          <div class="form-options">
            <label class="checkbox-label">
              <input type="checkbox" name="remember"> Remember me
            </label>
            <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
          </div>
          
          <button type="submit" class="portal-btn">
            Login to Portal
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
       <%- include('../partials/popup.ejs', { flash: flash }) %>
        </form>
        
        <div class="portal-footer">
          <p>New student? <a href="/admission">Contact Admissions</a></p>
        </div>
      </div>
    </div>

    <!-- Teacher Login Form -->
    <div class="tab-content" id="teacher">
      <div class="portal-card">
        <div class="portal-card-header">
          <div class="portal-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M22 6L12 13L2 6" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 13V20" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h2>Teacher Login</h2>
          <p>Manage classes, upload grades, and communicate with students</p>
        </div>
        
        <form class="portal-form" action="/login/teacher" method="POST">
          <div class="form-group">
            <label>Staff ID / Email</label>
            <%- include('../partials/forms.ejs', { type: 'email', name: 'email', placeholder: 'teacher@kingsfield.edu.ng' }) %>
          </div>
          
          <div class="form-group">
            <label>Password</label>
            <div class="password-wrapper">
              <%- include('../partials/forms.ejs', { type: 'password', name: 'password', placeholder: 'Enter your password' }) %>
              <button type="button" class="toggle-password">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </button>
            </div>
          </div>
          
          <div class="form-options">
            <label class="checkbox-label">
              <input type="checkbox" name="remember"> Keep me logged in
            </label>
            <a href="/forgot-password" class="forgot-link">Reset Password?</a>
          </div>
          
          <button type="submit" class="portal-btn">
            Access Dashboard
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
        
        <div class="portal-footer">
          <p>Need help? <a href="/contact">Contact IT Support</a></p>
        </div>
      </div>
    </div>

    <!-- Parent Login Form -->
    <div class="tab-content" id="parent">
      <div class="portal-card">
        <div class="portal-card-header">
          <div class="portal-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="9" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 21L16 21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h2>Parent Portal</h2>
          <p>Monitor your child's progress, fees, and school activities</p>
        </div>
        
        <form class="portal-form" action="/login/parent" method="POST">
          <div class="form-group">
            <label>Phone Number (Registered with school)</label>
            <%- include('../partials/forms.ejs', { type: 'tel', name: 'phone', placeholder: '08012345678' }) %>
          </div>
          
          <div class="form-group">
            <label>Password</label>
            <div class="password-wrapper">
              <%- include('../partials/forms.ejs', { type: 'password', name: 'password', placeholder: 'Enter your password' }) %>
              <button type="button" class="toggle-password">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z" stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                </svg>
              </button>
            </div>
          </div>
          
          <div class="form-options">
            <label class="checkbox-label">
              <input type="checkbox" name="remember"> Remember me
            </label>
            <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
          </div>
          
          <button type="submit" class="portal-btn">
            Sign In to Portal
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
        
        <div class="portal-footer">
          <p>⚠️ Lost your credentials? <a href="/contact">Contact School Admin</a></p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include("../partials/footer.ejs") %>

