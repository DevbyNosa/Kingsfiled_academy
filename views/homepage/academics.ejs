<section class="academic-levels">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Educational Pathway</span>
      <h2>Academic Levels at KingsField Academy</h2>
      <p>From foundation to graduation, we nurture excellence at every stage</p>
    </div>

    <div class="levels-grid">
      <!-- Early Years -->
      <div class="level-card">
        <div class="level-icon">
          <svg width="50" height="50" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Early Years (Crèche & Nursery)</h3>
        <div class="level-age">Ages 1 - 5</div>
        <p>Play-based learning that develops social skills, creativity, and foundational literacy in a nurturing environment.</p>
        <ul class="level-features">
          <li>Montessori-inspired activities</li>
          <li>Phonics and early numeracy</li>
          <li>Social-emotional development</li>
          <li>Creative arts and music</li>
        </ul>
      </div>

      <!-- Primary School -->
      <div class="level-card">
        <div class="level-icon">
          <svg width="50" height="50" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22 10L12 5L2 10L12 15L22 10Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 12V18C6 19.5 8 21 12 21C16 21 18 19.5 18 18V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Primary School</h3>
        <div class="level-age">Grades 1 - 6</div>
        <p>Building strong academic foundations through engaging, hands-on learning experiences across all core subjects.</p>
        <ul class="level-features">
          <li>Mathematics & English mastery</li>
          <li>Basic Science & Technology</li>
          <li>Computer literacy</li>
          <li>French & Civic Education</li>
        </ul>
      </div>

      <!-- Junior Secondary -->
      <div class="level-card">
        <div class="level-icon">
          <svg width="50" height="50" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 6V4M12 6C13.1046 6 14 6.89543 14 8C14 9.10457 13.1046 10 12 10M12 6C10.8954 6 10 6.89543 10 8C10 9.10457 10.8954 10 12 10M12 10V14M12 14C10.8954 14 10 14.8954 10 16C10 17.1046 10.8954 18 12 18M12 14C13.1046 14 14 14.8954 14 16C14 17.1046 13.1046 18 12 18M12 18V20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>Junior Secondary School (JSS)</h3>
        <div class="level-age">Grades 7 - 9</div>
        <p>Comprehensive curriculum preparing students for Senior Secondary with strong fundamentals in all core subjects.</p>
        <ul class="level-features">
          <li>Integrated Science</li>
          <li>Basic Technology & ICT</li>
          <li>Business Studies</li>
          <li>Creative & Cultural Arts</li>
        </ul>
      </div>

      <!-- Senior Secondary -->
      <div class="level-card">
        <div class="level-icon">
          <svg width="50" height="50" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15 8.5L22 9.5L17 14L18.5 21L12 17.5L5.5 21L7 14L2 9.5L9 8.5L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3>Senior Secondary School (SSS)</h3>
        <div class="level-age">Grades 10 - 12</div>
        <p>Specialized pathways preparing students for WASSCE, NECO, and university entrance examinations.</p>
        <ul class="level-features">
          <li>Science & Technology track</li>
          <li>Commercial/Business track</li>
          <li>Arts & Humanities track</li>
          <li>JAMB/UTME preparation</li>
        </ul>
      </div>
    </div>
  </div>
</section>

