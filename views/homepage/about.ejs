<section class="about-hero-section">
  <div class="about-hero-content">
    <span class="about-badge">Our Story</span>
    <h1>Shaping Tomorrow's <span class="highlight">Leaders Today</span></h1>
    <p>For over a decade, KingsField Academy has been the beacon of educational excellence in Benin City, nurturing young minds to become global citizens with strong values and academic prowess.</p>
  </div>
</section>

<section class="mission-vision-section">
  <div class="mission-vision-container">
    <div class="mv-card mission-card">
      <div class="mv-icon">
        <svg width="50" height="50" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3>Our Mission</h3>
      <p>To provide a transformative educational experience that empowers students with knowledge, critical thinking skills, and strong character to excel in a rapidly changing world.</p>
    </div>
    
    <div class="mv-card vision-card">
      <div class="mv-icon">
        <svg width="50" height="50" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 12C1 12 5 4 12 4C19 4 23 12 23 12C23 12 19 20 12 20C5 20 1 12 1 12Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </div>
      <h3>Our Vision</h3>
      <p>To become Nigeria's leading institution for holistic education, recognized globally for producing innovative thinkers, compassionate leaders, and responsible citizens.</p>
    </div>

    <div class="mv-card values-card">
      <div class="mv-icon">
        <svg width="50" height="50" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L15 8.5L22 9.5L17 14L18.5 21L12 17.5L5.5 21L7 14L2 9.5L9 8.5L12 2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h3>Core Values</h3>
      <p>Excellence • Integrity • Innovation • Respect • Resilience • Service</p>
    </div>
  </div>
</section>

<section class="stats-showcase">
  <div class="stats-container">
    <div class="stat-item">
      <div class="stat-number" data-target="12">0</div>
      <div class="stat-label">Years of Excellence</div>
    </div>
