<!-- Admission Process -->
<section id="admission-process" class="process-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Simple Steps</span>
      <h2>Admission Process</h2>
      <p>Follow these easy steps to enroll your child at KingsField Academy</p>
    </div>

    <div class="process-steps">
      <div class="step">
        <div class="step-number">01</div>
        <div class="step-content">
          <h3>Submit Application</h3>
          <p>Complete our online application form or visit the school to obtain an admission form. Pay the non-refundable application fee.</p>
          <a href="/apply" class="step-link">Apply Now →</a>
        </div>
      </div>
      <div class="step">
        <div class="step-number">02</div>
        <div class="step-content">
          <h3>Entrance Assessment</h3>
          <p>Schedule and take the placement test. We assess English, Mathematics, and General Knowledge appropriate for your child's grade level.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-number">03</div>
        <div class="step-content">
          <h3>Family Interview</h3>
          <p>Meet with our admissions team to discuss your child's educational needs, goals, and how KingsField can support their growth.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-number">04</div>
        <div class="step-content">
          <h3>Acceptance & Registration</h3>
          <p>Receive acceptance letter, complete registration forms, pay tuition fees, and secure your child's placement.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-number">05</div>
        <div class="step-content">
          <h3>Welcome to KingsField</h3>
          <p>Attend orientation, receive class schedule, purchase uniform and books, and start your journey with us!</p>
        </div>
      </div>
    </div>
  </div>
</section>

