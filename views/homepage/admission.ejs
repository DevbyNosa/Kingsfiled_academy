<!-- Fees Section -->
<section class="fees-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Investment in Future</span>
      <h2>Fee Structure</h2>
      <p>Transparent and affordable fees for quality education</p>
    </div>

    <div class="fees-grid">
      <div class="fee-card">
        <h3>Application Fee</h3>
        <div class="fee-amount">₦5,000</div>
        <p>Non-refundable application fee</p>
      </div>
      <div class="fee-card">
        <h3>Tuition (per term)</h3>
        <div class="fee-amount">₦70,000 - 120,000</div>
        <p>Tuition, library & materials</p>
      </div>
     <div class="fee-card">
      <h3>School Uniform</h3>
      <div class="fee-amount">₦30,000</div>
      <p>Complete set (2 shirts, 2 trousers/skirts, sweater, socks & tie)</p>
      </div>
      <div class="fee-card">
        <h3>Extracurricular</h3>
        <div class="fee-amount">₦25,000</div>
        <p>Sports, clubs & activities</p>
      </div>
    </div>

    <div class="fees-note">
      <p>✧ Uniform, textbooks, field trips, and exam fees (WAEC/NECO) are additional</p>
      <p>✧ Sibling discount: 10% for 2nd child, 15% for 3rd child</p>
      <p>✧ Payment plans available upon request</p>
    </div>
  </div>
</section>



