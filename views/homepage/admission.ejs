<!-- FAQ Section -->
<section class="faq-section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Common Questions</span>
      <h2>Frequently Asked Questions</h2>
      <p>Find answers to commonly asked questions about admissions</p>
    </div>

    <div class="faq-grid">
      <details class="faq-item">
        <summary>What is the age requirement for admission?</summary>
        <div class="faq-answer">
          <p>For Crèche: 1-2 years, Nursery: 3-5 years, Primary 1: 5+ years by September, JSS1: 10+ years, SSS1: 14+ years.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Is there a placement test?</summary>
        <div class="faq-answer">
          <p>Yes, all new students (except Crèche) take age-appropriate assessments in English, Mathematics, and General Knowledge.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Do you offer scholarships?</summary>
        <div class="faq-answer">
          <p>Yes! Merit-based scholarships are available for outstanding students. Contact admissions for more details.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Is transportation available?</summary>
        <div class="faq-answer">
          <p>Yes, we operate school buses on major routes within Benin City. Additional fees apply.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>Can I visit the campus before applying?</summary>
        <div class="faq-answer">
          <p>Absolutely! Campus tours are available Monday-Friday, 9am-3pm. Please call ahead to schedule.</p>
        </div>
      </details>
      <details class="faq-item">
        <summary>What curriculum do you follow?</summary>
        <div class="faq-answer">
          <p>We follow the Nigerian National Curriculum enhanced with international best practices and STEM focus.</p>
        </div>
      </details>
    </div>
  </div>
</section>

