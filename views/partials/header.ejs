 <section class="hero-section">
      <div class="hero-desc">
         <h1><%- page_header %></h1>
         <p><%= page_text %></p>

        
     <% if (typeof showButtons !== 'undefined' && showButtons === true) { %>
       <span class="hero-cta">
        <%- include('buttons.ejs', { link: '/about', text: 'Learn More', value: 'primary' }) %>
        <%- include('buttons.ejs', { link: '/admission', text: 'Apply Now', value: 'secondary' }) %>
       </span>
     <% } %>

     <% if (typeof customButtons !== 'undefined' && customButtons) { %>
       <span class="hero-cta">
         <%- customButtons %>
       </span>
     <% } %>
       </div>
       

       <div>
         <img src="https://images.unsplash.com/photo-1580067644090-a03da9d1e360?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mnx8c3R1ZGVudCUyMGluJTIwdW5pZm9ybXxlbnwwfHwwfHx8MA%3D%3D" alt="Test" class="hero-img">
       </div>
     </section>