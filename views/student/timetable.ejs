        <div class="timetable-row">
          <div class="timetable-cell time-col">2:30 - 3:00</div>
          <div class="timetable-cell">Study Hall<br><span class="teacher">Mr. Ade</span></div>
          <div class="timetable-cell">Civic Ed<br><span class="teacher">Mrs. Funke</span></div>
          <div class="timetable-cell">Sports<br><span class="teacher">Coach</span></div>
